{
  "rules": {
    "presence": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null && (auth.uid === $uid || (!newData.exists() && (!data.hasChild('t') || data.child('t').val() < now - 300000)))",
        ".validate": "newData.hasChildren(['name', 'systemIndex', 't'])"
      }
    },
    "poses": {
      ".read": "auth != null",
      "$sys": {
        "$uid": {
          ".write": "auth != null && (auth.uid === $uid || (!newData.exists() && (!data.hasChild('t') || data.child('t').val() < now - 300000)))",
          ".validate": "newData.hasChildren(['x', 'y', 'z', 't'])"
        }
      }
    },
    "portals": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null && auth.uid === $uid",
        ".validate": "newData.hasChildren(['galaxySeed', 'fromSystem', 'toSystem', 'radius', 'from', 'to', 'traveler', 't', 'expiresAt'])"
      }
    },
    "systemPortals": {
      ".read": "auth != null",
      "$sys": {
        "$uid": {
          ".write": "auth != null && auth.uid === $uid",
          ".validate": "newData.hasChildren(['galaxySeed', 'fromSystem', 'toSystem', 'radius', 'from', 'to', 'traveler', 't', 'expiresAt'])"
        }
      }
    },
    "chats": {
      "$cid": {
        ".read": "auth != null && $cid.contains(auth.uid)",
        ".write": "auth != null && $cid.contains(auth.uid)",
        "messages": {
          "$mid": {
            ".validate": "newData.hasChildren(['from', 'text']) && newData.child('from').val() === auth.uid"
          }
        }
      }
    },
    "inbox": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        "$from": {
          ".write": "auth != null && ($from === auth.uid || auth.uid === $uid)",
          ".validate": "auth.uid === $uid || newData.hasChildren(['name'])"
        }
      }
    },
    "hits": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        "$hid": {
          ".write": "auth != null && ((!data.exists() && newData.child('from').val() === auth.uid) || auth.uid === $uid)",
          ".validate": "newData.hasChildren(['dmg', 'from']) && newData.child('dmg').isNumber() && newData.child('from').val() === auth.uid"
        }
      }
    }
  }
}
