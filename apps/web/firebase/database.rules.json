{
  "//": "Star Elite — правила Realtime Database (присутствие). Применить: Firebase Console →",
  "//1": "Realtime Database → вкладка Rules → вставить и Publish. Читать список онлайн может",
  "//2": "любой вошедший; писать/стирать МОЖНО только свой узел presence/{uid} (auth.uid).",
  "rules": {
    "presence": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null && auth.uid === $uid",
        ".validate": "newData.hasChildren(['name', 'systemIndex'])"
      }
    },
    "chats": {
      "$cid": {
        ".read": "auth != null && $cid.contains(auth.uid)",
        ".write": "auth != null && $cid.contains(auth.uid)",
        "messages": {
          "$mid": {
            ".validate": "newData.hasChildren(['from', 'text']) && newData.child('from').val() === auth.uid"
          }
        }
      }
    },
    "inbox": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        "$from": {
          ".write": "auth != null && ($from === auth.uid || auth.uid === $uid)",
          ".validate": "auth.uid === $uid || newData.hasChildren(['name'])"
        }
      }
    }
  }
}
