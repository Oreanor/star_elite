# Переговоры с кораблями через языковую модель (клавиша T в полёте).
# Скопируй в apps/web/.env и впиши свой ключ. Без ключа чат просто выключен:
# в окне остаются кнопки механик (сдаться / нанять / ограбить), разговора нет.
#
# Ключ уходит в клиентский бандл — это НОРМАЛЬНО для локальной игры и НЕ годится
# для публичной сборки. Появится apps/server — запрос переедет за прокси, ключ спрячется.

# Ключ OpenRouter (https://openrouter.ai/keys). Free-моделей хватает без оплаты.
VITE_OPENROUTER_API_KEY=

# Необязательно: свой список моделей через запятую, от лучших к худшим.
# Пусто — берётся встроенный список free-моделей. Перебор идёт по очереди:
# первая, что ответила разборным JSON, побеждает; все молчат — «плохая связь».
# VITE_OPENROUTER_MODELS=deepseek/deepseek-chat-v3-0324:free,meta-llama/llama-3.3-70b-instruct:free
