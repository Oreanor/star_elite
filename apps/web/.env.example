# Переговоры с кораблями через языковую модель (клавиша T в полёте).
# Скопируй в КОРЕНЬ репозитория как .env.local и впиши ключ (Vite читает env оттуда,
# envDir='../../'). Без ключа чат просто выключен: в окне остаются кнопки механик
# (сдаться / нанять / ограбить / приказы эскорту), свободного разговора нет.
#
# Ключ уходит в клиентский бандл — это НОРМАЛЬНО для локальной игры и НЕ годится
# для публичной сборки. Появится apps/server — запрос переедет за прокси, ключ спрячется.

# --- Groq (РЕКОМЕНДУЕТСЯ): https://console.groq.com/keys, бесплатно ---
# Инференс за доли секунды и свободный лимит — в отличие от вечно забитого free-пула
# OpenRouter. Если задан, говорим через него; OpenRouter остаётся запасным.
VITE_GROQ_API_KEY=

# --- OpenRouter (запасной): https://openrouter.ai/keys ---
VITE_OPENROUTER_API_KEY=

# Необязательно: свои списки моделей через запятую, от лучших к худшим (пусто —
# встроенные). Внутри провайдера модели гонятся параллельно, берётся первый
# разборный ответ; Groq пробуется раньше OpenRouter.
# VITE_GROQ_MODELS=llama-3.1-8b-instant,llama-3.3-70b-versatile
# VITE_OPENROUTER_MODELS=openai/gpt-oss-120b:free,meta-llama/llama-3.3-70b-instruct:free

# --- Сеть (Firebase): аккаунты, серверные сейвы, присутствие ---
# Пусто/нет → игра идёт ОФЛАЙН (localStorage), без входа и без сервера. Заданы ключи →
# онлайн: экран входа, прогресс на сервере. Значения: Firebase Console → Project settings →
# «Your apps» (Web app) → SDK config. Ключи Firebase ПУБЛИЧНЫ намеренно (доступ рулят
# Firestore Rules) — держать в клиенте нормально. В консоли включи Authentication →
# Email/Password, и один раз применить правила из apps/web/firebase/firestore.rules.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
